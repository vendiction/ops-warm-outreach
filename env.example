# ===== OPS-WARM-OUTREACH — .env template =====
# Copy to .env and fill. Never commit .env (it's gitignored).
# Vars are grouped: [TEST] = needed for the 2-IG + 1-Proton demo (SETUP_TEST.md);
# [REAL] = only needed for the full/volume run.

# =========================================================================
# [TEST] Database — Supabase session pooler (port 5432, NOT 6543)
# This single URL replaces the old POSTGRES_* split vars. Every service reads it.
# =========================================================================
DATABASE_URL=postgres://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:5432/postgres

# =========================================================================
# [TEST] Anthropic — scoring, drafting, reply triage
# =========================================================================
ANTHROPIC_API_KEY=
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_OPUS_MODEL=claude-opus-4-7

# =========================================================================
# [TEST] Discord — HITL bot + hot-lead pings
# =========================================================================
DISCORD_BOT_TOKEN=
DISCORD_HITL_CHANNEL_ID=
# Webhook URL (channel > Integrations > Webhooks) for interested-reply alerts:
DISCORD_HOTLEAD_WEBHOOK=
# Webhook for the daily/weekly digest (can be the same channel):
DISCORD_DIGEST_WEBHOOK=

# =========================================================================
# [TEST] Send console — human DM queue
# =========================================================================
DM_DAILY_CAP=20


# =========================================================================
# [TEST] ProtonMail disposable inbox pool (the audit worker)
# Path to a gitignored JSON file with per-inbox creds. Shape:
#   [{"address":"you@proton.me","imap_host":"127.0.0.1","imap_port":1143,"user":"you@proton.me","pass":"..."}]
# =========================================================================
PROTONMAIL_POOL_FILE=./secrets/protonmail_pool.json
INBOX_MAX_PER_WEEK=5
INBOX_COOLDOWN_HOURS=48
INBOX_STATE_FILE=./secrets/inbox_state.json

# =========================================================================
# [REAL] Cold email — dispatch through the existing 15-inbox n8n stack
# The send_cold_email workflow POSTs due emails to this intake webhook.
# =========================================================================
COLD_EMAIL_SEND_WEBHOOK=

# =========================================================================
# [REAL] Sourcing / enrichment data sources
# =========================================================================
APOLLO_API_KEY=
SIMILARWEB_API_KEY=

# =========================================================================
# [REAL] Residential proxies (IPRoyal) — audit worker + scrapers
# Used only when doing real audits against real prospect sites at volume.
# Format host:port; sticky-session suffix is added automatically.
# =========================================================================
IPROYAL_PROXY=geo.iproyal.com:12321
IPROYAL_PROXY_USER=
IPROYAL_PROXY_PASS=

# =========================================================================
# [REAL] social_posts scraper — needs a warmed SCRAPING persona (Dolphin)
# Leave blank in the test; the scraper returns [] and enrichment still completes.
# =========================================================================
DOLPHIN_API_URL=http://localhost:3001
SCRAPE_IG_DOLPHIN_PROFILE=
SCRAPE_LI_DOLPHIN_PROFILE=

# =========================================================================
# [REAL] Metabase (analytics container in docker-compose.yml)
# =========================================================================
METABASE_BASE_URL=
METABASE_DB_USER=metabase_user
METABASE_DB_PASS=
METABASE_ENCRYPTION_KEY=
METABASE_RO_USER=metabase_ro
METABASE_RO_PASS=

# =========================================================================
# Optional tuning (safe defaults exist in code)
# =========================================================================
DIGEST_TZ=Asia/Manila
LOG_LEVEL=INFO
# AUDIT_HEADLESS=true
# HITL_POLL_SECONDS=30
